# ASR
VOICEKB_WHISPER_MODEL=small
VOICEKB_WHISPER_DEVICE=cuda          # cuda or cpu
VOICEKB_WHISPER_COMPUTE_TYPE=float16  # auto for cpu

# LLM
VOICEKB_LLM_BACKEND=openai_compatible
VOICEKB_LLM_BASE_URL=http://localhost:18090/v1
VOICEKB_LLM_MODEL=Qwen/Qwen3-8B
VOICEKB_LLM_API_KEY=not-needed

# Server
VOICEKB_PORT=18089

# Data is stored in ~/.voicekb/ by default. Override only if needed:
# VOICEKB_DATA_DIR=/custom/path
